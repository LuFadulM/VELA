# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vela?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Nylas (email/calendar unified API)
NYLAS_CLIENT_ID=
NYLAS_CLIENT_SECRET=
NYLAS_API_KEY=

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Slack / Zoom / Google OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=replace-me-with-a-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use "true" to run without external APIs — uses built-in mock data
NEXT_PUBLIC_MOCK_MODE=true
